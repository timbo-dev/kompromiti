{
    "compilerOptions": {
        "target": "ES5",
        "module": "CommonJS",
        "isolatedModules": true,
        "esModuleInterop": true,
        "outDir": "lib",
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "strictNullChecks": false
    }
}
