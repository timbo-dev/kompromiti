        "name": "Nathan Rocha"
    },
    "license": "MIT",
    "dependencies": {
        "typescript": "^5.1.6"
    },
    "devDependencies": {
        "@stryker-mutator/core": "^7.1.1",
        "@swc/cli": "^0.1.62",
        "@swc/core": "^1.3.73",
        "@types/node": "^20.4.5",
        "glob": "^10.3.3",
        "vitest": "^0.34.1"
    }
}
