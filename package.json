{
    "private": true,
    "name": "kompromiti",
    "type": "commonjs",
    "version": "1.0.0",
    "description": "A tool to improve commit creation and management in software development projects.",
    "packageManager": "pnpm@8.6.11",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "tsc --noEmit && make build"
    },
    "keywords": [
        "kompromiti",
        "commit",
        "commit message",
        "version control",
        "code quality",
        "software development"
    ],
    "repository": {
